# xAI / Grok
XAI_API_KEY=xai-your-key-here

# PostgreSQL – Supabase or local
# Supabase example: postgresql+asyncpg://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aipulse

# Sync URL for Alembic migrations (uses psycopg2)
SYNC_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/aipulse

# Admin password for /api/admin/refresh
ADMIN_PASSWORD=changeme_in_production

# CORS origin for Next.js frontend
FRONTEND_ORIGIN=http://localhost:3000

# Scheduler timezone
SCHEDULER_TIMEZONE=America/Boise
